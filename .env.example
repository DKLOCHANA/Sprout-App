# Firebase Configuration
# Copy this file to .env and fill in your Firebase credentials
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# RevenueCat Configuration
# Production API Key (iOS) - Use in production builds
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_production_key
# Test API Key (iOS) - Use for development/testing in sandbox
EXPO_PUBLIC_REVENUECAT_IOS_TEST_KEY=test_your_test_key
# Android keys (to be added when Android support is added)
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_TEST_KEY=
